# App
NODE_ENV=production
PORT=3001
APP_URL=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app

# Database — use DATABASE_URL for Neon/Render (preferred in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# OR individual vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vietmy_callcenter
DB_USER=postgres
DB_PASS=your-db-password
DB_SYNC=true
DB_LOGGING=false

# JWT — generate strong random secrets for production!
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# 2FA
TWO_FA_APP_NAME=VietMyCallCenter

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880
